{
  "name": "github-collab-git",
  "version": "1.0.0",
  "description": "GitHub 协作 Agent 系统 - 统一数据库版本（支持 Agent 和任务管理）",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node index.js",
    "test": "node test/index.js",
    "db:init": "node scripts/init-db.js",
    "db:list": "node scripts/update-agent.js list",
    "db:sync": "node scripts/sync-config.js",
    "db:validate": "node scripts/validate-config.js",
    "config": "node scripts/config-cli.js",
    "config:status": "node scripts/config-cli.js status",
    "config:list": "node scripts/config-cli.js list",
    "config:update": "node scripts/config-cli.js update",
    "config:backup": "node scripts/config-cli.js backup",
    "config:restore": "node scripts/config-cli.js restore",
    "config:export": "node scripts/config-cli.js export",
    "config:import": "node scripts/config-cli.js import",
    "config:cleanup": "node scripts/config-cli.js cleanup",
    "config:summary": "node scripts/config-cli.js summary",
    "task:list": "node scripts/config-cli.js task:list",
    "task:show": "node scripts/config-cli.js task:show",
    "task:assign": "node scripts/config-cli.js task:assign",
    "task:complete": "node scripts/config-cli.js task:complete",
    "task:stats": "node scripts/config-cli.js task:stats"
  },
  "keywords": [
    "agent",
    "collaboration",
    "github",
    "automation",
    "task-management"
